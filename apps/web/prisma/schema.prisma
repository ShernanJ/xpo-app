// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  handle        String?   @unique
  activeXHandle String?
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  onboardingRuns OnboardingRun[]
  posts          Post[]
  memories       ConversationMemory[]
  voiceProfiles  VoiceProfile[]
  chatThreads    ChatThread[]
  feedbackSubmissions FeedbackSubmission[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OnboardingRun {
  id        String   @id @default(uuid())
  userId    String?
  input     Json
  result    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  memories ConversationMemory[]
}

model ChatThread {
  id        String   @id @default(cuid())
  userId    String
  xHandle   String?
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories ConversationMemory[]
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  data      Json?    // Optional JSON data for stored chat payload fields
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id // X Post ID
  userId    String?
  xHandle   String?
  text      String
  lane      String // "original" | "reply" | "quote"
  metrics   Json // { likeCount, replyCount, repostCount, quoteCount }
  createdAt DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationMemory {
  id                  String   @id @default(uuid())
  userId              String?
  runId               String?  // Made optional for legacy compatibility
  threadId            String?
  topicSummary        String?
  activeConstraints   Json? // Array of strings
  concreteAnswerCount Int      @default(0)
  lastDraftArtifactId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  run    OnboardingRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
  thread ChatThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model VoiceProfile {
  id        String   @id @default(uuid())
  userId    String
  xHandle   String?
  niche     String?
  styleCard Json // Parsed CreatorStyleCard
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackSubmission {
  id                    String   @id @default(uuid())
  userId                String
  xHandle               String
  category              String
  status                String   @default("open")
  title                 String?
  message               String   @db.Text
  fields                Json
  context               Json
  attachments           Json
  submittedByUserHandle String?
  submittedByXHandle    String?
  statusUpdatedAt       DateTime?
  statusUpdatedByUserId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, xHandle, createdAt])
  @@index([userId, xHandle, status, createdAt])
}
