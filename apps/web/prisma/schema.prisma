// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BillingPlan {
  free
  pro
  lifetime
}

enum BillingStatus {
  active
  past_due
  canceled
  blocked_fair_use
}

enum BillingCycle {
  monthly
  annual
  lifetime
}

enum CreditActionType {
  monthly_grant
  debit
  refund
  manual_adjustment
  migration_grant
}

enum LifetimeReservationStatus {
  pending
  completed
  expired
  canceled
}

enum ChatMessageFeedbackValue {
  up
  down
}

model User {
  id            String    @id @default(uuid())
  handle        String?   @unique
  activeXHandle String?
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  onboardingRuns OnboardingRun[]
  posts          Post[]
  memories       ConversationMemory[]
  voiceProfiles  VoiceProfile[]
  chatThreads    ChatThread[]
  chatMessageFeedbacks ChatMessageFeedback[]
  feedbackSubmissions FeedbackSubmission[]
  billingEntitlement      BillingEntitlement?
  creditLedgerEntries     CreditLedgerEntry[]
  lifetimeSlotReservations LifetimeSlotReservation[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OnboardingRun {
  id        String   @id @default(uuid())
  userId    String?
  input     Json
  result    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  memories ConversationMemory[]
}

model ChatThread {
  id        String   @id @default(cuid())
  userId    String
  xHandle   String?
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories ConversationMemory[]
  messages ChatMessage[]
  messageFeedbacks ChatMessageFeedback[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  data      Json?    // Optional JSON data for stored chat payload fields
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  feedback ChatMessageFeedback[]
}

model ChatMessageFeedback {
  id        String                   @id @default(cuid())
  userId    String
  threadId  String
  messageId String
  value     ChatMessageFeedbackValue
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread  ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([messageId])
  @@index([threadId, createdAt])
  @@index([userId, createdAt])
}

model Post {
  id        String   @id // X Post ID
  userId    String?
  xHandle   String?
  text      String
  lane      String // "original" | "reply" | "quote"
  metrics   Json // { likeCount, replyCount, repostCount, quoteCount }
  createdAt DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationMemory {
  id                  String   @id @default(uuid())
  userId              String?
  runId               String?  // Made optional for legacy compatibility
  threadId            String?
  topicSummary        String?
  activeConstraints   Json? // Array of strings
  concreteAnswerCount Int      @default(0)
  lastDraftArtifactId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  run    OnboardingRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
  thread ChatThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model VoiceProfile {
  id        String   @id @default(uuid())
  userId    String
  xHandle   String?
  niche     String?
  styleCard Json // Parsed CreatorStyleCard
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackSubmission {
  id                    String   @id @default(uuid())
  userId                String
  xHandle               String
  category              String
  status                String   @default("open")
  title                 String?
  message               String   @db.Text
  fields                Json
  context               Json
  attachments           Json
  submittedByUserHandle String?
  submittedByXHandle    String?
  statusUpdatedAt       DateTime?
  statusUpdatedByUserId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, xHandle, createdAt])
  @@index([userId, xHandle, status, createdAt])
}

model BillingEntitlement {
  id                     String       @id @default(cuid())
  userId                 String       @unique
  plan                   BillingPlan  @default(free)
  status                 BillingStatus @default(active)
  billingCycle           BillingCycle @default(monthly)
  stripeCustomerId       String?      @unique
  stripeSubscriptionId   String?
  stripePriceId          String?
  creditsRemaining       Int          @default(100)
  creditLimit            Int          @default(100)
  creditCycleResetsAt    DateTime
  showFirstPricingModal  Boolean      @default(true)
  lifetimeGrantedAt      DateTime?
  fairUseSoftWarningAt   DateTime?
  fairUseReviewAt        DateTime?
  fairUseBlockedAt       DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditLedgerEntries CreditLedgerEntry[]

  @@index([plan, status])
  @@index([creditCycleResetsAt])
}

model CreditLedgerEntry {
  id                   String           @id @default(cuid())
  userId               String
  billingEntitlementId String?
  actionType           CreditActionType
  deltaCredits         Int
  balanceAfter         Int
  idempotencyKey       String?          @unique
  source               String?
  metadata             Json?
  createdAt            DateTime         @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entitlement BillingEntitlement? @relation(fields: [billingEntitlementId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([billingEntitlementId, createdAt])
}

model StripeWebhookEvent {
  id          String   @id
  eventType   String
  payload     Json
  status      String   @default("processing")
  errorMessage String?
  receivedAt  DateTime @default(now())
  processedAt DateTime?
}

model LifetimeSlotReservation {
  id                      String                    @id @default(cuid())
  userId                  String
  stripeCheckoutSessionId String?                   @unique
  status                  LifetimeReservationStatus @default(pending)
  expiresAt               DateTime
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  completedAt             DateTime?
  canceledAt              DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([userId, status, createdAt])
}
