// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BillingPlan {
  free
  pro
  lifetime
}

enum BillingStatus {
  active
  past_due
  canceled
  blocked_fair_use
}

enum BillingCycle {
  monthly
  annual
  lifetime
}

enum CreditActionType {
  monthly_grant
  debit
  refund
  manual_adjustment
  migration_grant
}

enum LifetimeReservationStatus {
  pending
  completed
  expired
  canceled
}

enum ChatMessageFeedbackValue {
  up
  down
}

enum DraftCandidateStatus {
  pending
  approved
  rejected
  edited
  posted
  observed
}

enum SourceMaterialType {
  story
  playbook
  framework
  case_study
}

model User {
  // Mirrors Supabase auth.users.id
  id            String   @id
  handle        String?  @unique
  activeXHandle String?
  name          String?
  email         String?  @unique
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  onboardingRuns           OnboardingRun[]
  posts                    Post[]
  memories                 ConversationMemory[]
  voiceProfiles            VoiceProfile[]
  chatThreads              ChatThread[]
  draftCandidates          DraftCandidate[]
  chatMessageFeedbacks     ChatMessageFeedback[]
  feedbackSubmissions      FeedbackSubmission[]
  sourceMaterialAssets     SourceMaterialAsset[]
  productEvents            ProductEvent[]
  billingEntitlement       BillingEntitlement?
  creditLedgerEntries      CreditLedgerEntry[]
  lifetimeSlotReservations LifetimeSlotReservation[]
}

model OnboardingRun {
  id        String   @id @default(uuid())
  userId    String?
  input     Json
  result    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  memories        ConversationMemory[]
  draftCandidates DraftCandidate[]
}

model ScrapeCaptureCache {
  id        String   @id @default(cuid())
  captureId String   @unique
  account   String   @unique
  capturedAt DateTime
  expiresAt DateTime
  profile   Json
  posts     Json
  replyPosts Json
  quotePosts Json
  source    String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@index([capturedAt])
}

model ChatThread {
  id        String   @id @default(cuid())
  userId    String
  xHandle   String?
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories        ConversationMemory[]
  messages        ChatMessage[]
  draftCandidates DraftCandidate[]
  messageFeedbacks ChatMessageFeedback[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  data      Json?    // Optional JSON data for stored chat payload fields
  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  feedback ChatMessageFeedback[]
}

model ChatMessageFeedback {
  id        String                   @id @default(cuid())
  userId    String
  threadId  String
  messageId String
  value     ChatMessageFeedbackValue
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread  ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([messageId])
  @@index([threadId, createdAt])
  @@index([userId, createdAt])
}

model Post {
  id        String   @id // X Post ID
  userId    String?
  xHandle   String?
  text      String
  lane      String // "original" | "reply" | "quote"
  metrics   Json // { likeCount, replyCount, repostCount, quoteCount }
  createdAt DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationMemory {
  id                  String   @id @default(uuid())
  userId              String?
  runId               String?  // Made optional for legacy compatibility
  threadId            String?
  topicSummary        String?
  activeConstraints   Json? // Array of strings
  concreteAnswerCount Int      @default(0)
  lastDraftArtifactId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  run    OnboardingRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
  thread ChatThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model VoiceProfile {
  id        String   @id @default(uuid())
  userId    String
  xHandle   String?
  niche     String?
  styleCard Json // Parsed CreatorStyleCard
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SourceMaterialAsset {
  id         String             @id @default(cuid())
  userId     String
  xHandle    String?
  type       SourceMaterialType
  title      String
  tags       Json
  verified   Boolean            @default(false)
  claims     Json
  snippets   Json
  doNotClaim Json
  lastUsedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, xHandle, verified, updatedAt])
  @@index([userId, xHandle, lastUsedAt])
}

model DraftCandidate {
  id              String               @id @default(cuid())
  userId          String
  xHandle         String?
  threadId        String?
  runId           String?
  title           String
  sourcePrompt    String
  sourcePlaybook  String?
  outputShape     String
  status          DraftCandidateStatus @default(pending)
  artifact        Json
  voiceTarget     Json?
  noveltyNotes    Json?
  rejectionReason String?
  approvedAt      DateTime?
  editedAt        DateTime?
  postedAt        DateTime?
  observedAt      DateTime?
  observedMetrics Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ChatThread?    @relation(fields: [threadId], references: [id], onDelete: SetNull)
  run    OnboardingRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([userId, xHandle, status, createdAt])
  @@index([threadId, createdAt])
  @@index([runId, createdAt])
}

model ProductEvent {
  id         String   @id @default(cuid())
  userId     String
  xHandle    String?
  threadId   String?
  messageId  String?
  candidateId String?
  eventType  String
  properties Json
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, eventType, createdAt])
  @@index([threadId, createdAt])
}

model FeedbackSubmission {
  id                    String   @id @default(uuid())
  userId                String
  xHandle               String
  category              String
  status                String   @default("open")
  title                 String?
  message               String   @db.Text
  fields                Json
  context               Json
  attachments           Json
  submittedByUserHandle String?
  submittedByXHandle    String?
  statusUpdatedAt       DateTime?
  statusUpdatedByUserId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, xHandle, createdAt])
  @@index([userId, xHandle, status, createdAt])
}

model BillingEntitlement {
  id                     String       @id @default(cuid())
  userId                 String       @unique
  plan                   BillingPlan  @default(free)
  status                 BillingStatus @default(active)
  billingCycle           BillingCycle @default(monthly)
  stripeCustomerId       String?      @unique
  stripeSubscriptionId   String?
  stripePriceId          String?
  creditsRemaining       Int          @default(100)
  creditLimit            Int          @default(100)
  creditCycleResetsAt    DateTime
  showFirstPricingModal  Boolean      @default(true)
  lifetimeGrantedAt      DateTime?
  fairUseSoftWarningAt   DateTime?
  fairUseReviewAt        DateTime?
  fairUseBlockedAt       DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditLedgerEntries CreditLedgerEntry[]

  @@index([plan, status])
  @@index([creditCycleResetsAt])
}

model CreditLedgerEntry {
  id                   String           @id @default(cuid())
  userId               String
  billingEntitlementId String?
  actionType           CreditActionType
  deltaCredits         Int
  balanceAfter         Int
  idempotencyKey       String?          @unique
  source               String?
  metadata             Json?
  createdAt            DateTime         @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entitlement BillingEntitlement? @relation(fields: [billingEntitlementId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([billingEntitlementId, createdAt])
}

model StripeWebhookEvent {
  id          String   @id
  eventType   String
  payload     Json
  status      String   @default("processing")
  errorMessage String?
  receivedAt  DateTime @default(now())
  processedAt DateTime?
}

model LifetimeSlotReservation {
  id                      String                    @id @default(cuid())
  userId                  String
  stripeCheckoutSessionId String?                   @unique
  status                  LifetimeReservationStatus @default(pending)
  expiresAt               DateTime
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  completedAt             DateTime?
  canceledAt              DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([userId, status, createdAt])
}
