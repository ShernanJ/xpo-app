{
  "name": "stanley-x-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:inngest": "INNGEST_DEV=1 next dev",
    "build": "prisma generate && next build && node scripts/verify-output-file-tracing.mjs",
    "prestart": "prisma migrate deploy && node scripts/verify-required-db-tables.mjs",
    "start": "next start",
    "deploy:prepare": "pnpm exec prisma migrate deploy && node scripts/verify-required-db-tables.mjs",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:verify:schema": "node scripts/verify-required-db-tables.mjs",
    "lint": "eslint",
    "test:coach-reply": "node --test --experimental-strip-types lib/onboarding/coachReply.test.mjs",
    "test:draft-validator": "node --test --experimental-strip-types lib/onboarding/draftValidator.test.mjs",
    "test:ui": "vitest run",
    "test:lib": "vitest run --config vitest.lib.config.ts",
    "test:ui:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "inngest:dev": "pnpm dlx inngest-cli@latest dev -u http://localhost:3000/api/inngest --no-discovery",
    "inngest:prod:local": "sh -c 'test -n \"$INNGEST_EVENT_KEY\" && test -n \"$INNGEST_SIGNING_KEY\" && pnpm dlx inngest-cli@latest start --event-key \"$INNGEST_EVENT_KEY\" --signing-key \"$INNGEST_SIGNING_KEY\" || (echo \"INNGEST_EVENT_KEY and INNGEST_SIGNING_KEY are required\" && exit 1)'",
    "test:frontend": "pnpm run test:ui && pnpm run test:e2e",
    "test:v2-response-quality": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/agent-v2/responseQuality.test.mjs",
    "test:v2-regressions": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/agent-v2/regressions/chatRegression.test.mjs",
    "test:v2-runtime": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/agent-v2/runtime/conversationManager.test.mjs",
    "test:v2-route": "node --test --experimental-strip-types --experimental-specifier-resolution=node app/api/creator/v2/chat/route.test.mjs",
    "test:v2-feedback": "node --test --experimental-strip-types --experimental-specifier-resolution=node app/api/creator/v2/feedback/route.test.mjs",
    "test:v2-preferences": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/agent-v2/core/preferenceConstraints.test.mjs",
    "test:v2-source-materials": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/agent-v2/grounding/sourceMaterials.test.mjs app/api/creator/v2/source-materials/route.test.mjs",
    "test:v2-policy": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/agent-v2/core/finalDraftPolicy.test.mjs",
    "test:transcript-replay": "node --test --experimental-strip-types --experimental-specifier-resolution=node scripts/lib/creator-transcript-replay.test.mjs",
    "test:billing-policy": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/billing/policy.test.mjs",
    "test:extension": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/extension/auth.test.ts lib/extension/connect.test.ts lib/extension/handles.test.ts lib/extension/opportunityBatch.test.ts lib/extension/replyDraft.test.ts lib/extension/replyOpportunities.test.ts lib/extension/replyOptions.test.ts lib/reply-engine/preflight.test.ts lib/reply-engine/goldenExamples.test.ts app/api/extension/drafts/route.test.mjs \"app/api/extension/drafts/[id]/publish/route.test.mjs\" app/api/extension/handles/route.test.mjs app/api/extension/opportunity-batch/route.test.mjs app/api/extension/reply-options/route.test.mjs app/api/extension/reply-log/route.test.mjs app/api/extension/reply-draft/route.test.mjs",
    "test:v3-runtime": "node --test --experimental-strip-types --experimental-specifier-resolution=node lib/agent-v2/regressions/v3Runtime.test.mjs",
    "test:v2": "pnpm run test:v2-response-quality && pnpm run test:v2-regressions && pnpm run test:v2-runtime && pnpm run test:v2-route && pnpm run test:v2-feedback && pnpm run test:v2-preferences && pnpm run test:v2-source-materials && pnpm run test:v2-policy && pnpm run test:billing-policy && pnpm run test:v3-runtime",
    "worker:background": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/process-background-jobs.mjs",
    "replay:creator-transcript": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/replay-creator-transcript.mjs",
    "capture:user-tweets": "node scripts/capture-user-tweets-playwright.mjs",
    "scrape:user-tweets:http": "node scripts/scrape-user-tweets-http.mjs",
    "verify:output-file-tracing": "node scripts/verify-output-file-tracing.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "ai": "^6.0.134",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.0",
    "groq-sdk": "^0.37.0",
    "inngest": "^4.0.4",
    "jose": "^6.1.3",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "openai": "^6.32.0",
    "pg": "^8.19.0",
    "posthog-js": "^1.360.2",
    "posthog-node": "^5.28.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.8",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "3.23.2",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
