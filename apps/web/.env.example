# -----------------------------------------------------------------------------
# XPO WEB APP ENVIRONMENT TEMPLATE
# Copy to .env (local) or set in your deployment provider.
# Do not commit real secrets.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Core app (required)
# -----------------------------------------------------------------------------
DATABASE_URL=
DATABASE_MIGRATION_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SESSION_SECRET=
# NEXTAUTH_* variables are deprecated. Auth is handled via Supabase + sx_session.

# AI provider (required for chat/agents)
GROQ_API_KEY=
# Optional override. Default in code: openai/gpt-oss-120b
GROQ_MODEL=

# -----------------------------------------------------------------------------
# Public app URLs + support (recommended)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=

# -----------------------------------------------------------------------------
# Pricing display values (optional UI overrides)
# Used in landing/pricing/chat display when set.
# -----------------------------------------------------------------------------
# Display currency for UI pricing labels. Defaults to CAD.
# Allowed values: CAD | USD
NEXT_PUBLIC_BILLING_DISPLAY_CURRENCY=CAD

NEXT_PUBLIC_BILLING_PRICE_PRO_MONTHLY_CAD=
NEXT_PUBLIC_BILLING_PRICE_PRO_ANNUAL_CAD=
NEXT_PUBLIC_BILLING_PRICE_FOUNDER_PASS_CAD=
# Legacy alias still supported by code
NEXT_PUBLIC_BILLING_PRICE_LIFETIME_CAD=

# Legacy USD aliases (optional fallback)
NEXT_PUBLIC_BILLING_PRICE_PRO_MONTHLY_USD=
NEXT_PUBLIC_BILLING_PRICE_PRO_ANNUAL_USD=
NEXT_PUBLIC_BILLING_PRICE_FOUNDER_PASS_USD=
NEXT_PUBLIC_BILLING_PRICE_LIFETIME_USD=

# Server-side pricing overrides (optional)
BILLING_PRICE_PRO_MONTHLY_CAD=
BILLING_PRICE_PRO_ANNUAL_CAD=
BILLING_PRICE_FOUNDER_PASS_CAD=
# Legacy alias still supported by code
BILLING_PRICE_LIFETIME_CAD=

# Legacy USD aliases (optional fallback)
BILLING_PRICE_PRO_MONTHLY_USD=
BILLING_PRICE_PRO_ANNUAL_USD=
BILLING_PRICE_FOUNDER_PASS_USD=
BILLING_PRICE_LIFETIME_USD=

# -----------------------------------------------------------------------------
# Stripe billing (required if checkout/webhooks are enabled)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_LIFETIME=

# -----------------------------------------------------------------------------
# Onboarding source selection
# ONBOARDING_MODE: auto | scrape | x_api | mock
# ONBOARDING_DATA_SOURCE is legacy alias and still supported.
# -----------------------------------------------------------------------------
ONBOARDING_MODE=auto
ONBOARDING_DATA_SOURCE=
# Production safety: when unset/0 in production, mock fallback is rejected.
# Set to 1 only if you intentionally want mock onboarding in prod.
ONBOARDING_ALLOW_MOCK_FALLBACK=

# X API mode (needed only when ONBOARDING_MODE=x_api)
X_API_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Scrape mode / web scraping credentials (needed for scrape source)
# -----------------------------------------------------------------------------
X_WEB_COOKIE=
X_WEB_CSRF_TOKEN=
# Optional fallback only. If blank, app tries auto-discovery from x.com scripts.
X_WEB_BEARER_TOKEN=
# Optional. If blank, app uses a built-in browser-like default user agent.
X_WEB_USER_AGENT=

# Scrape pacing / state (optional)
X_WEB_SCRAPE_STATE_PATH=
X_WEB_MAX_REQUESTS_PER_HOUR=
X_WEB_MIN_INTERVAL_MS=
X_WEB_COOLDOWN_MS=
X_WEB_REQUEST_DELAY_MS=
X_WEB_REQUEST_JITTER_MS=
X_WEB_PAGES=
X_WEB_SESSION_FILE=
X_WEB_USER_TWEETS_QUERY_ID=
X_WEB_USER_ID=

# Onboarding scrape bootstrap defaults (optional)
ONBOARDING_SCRAPE_PAGES=
ONBOARDING_SCRAPE_COUNT=

# Profile refresh throttles (optional)
# Defaults: manual=10 minutes, daily interval=24 hours
PROFILE_SCRAPE_MANUAL_COOLDOWN_MINUTES=
PROFILE_SCRAPE_DAILY_INTERVAL_HOURS=

# -----------------------------------------------------------------------------
# Onboarding backfill queue tuning (optional)
# -----------------------------------------------------------------------------
ONBOARDING_BACKFILL_PAGES=
ONBOARDING_BACKFILL_COUNT=
ONBOARDING_BACKFILL_STORE_PATH=
ONBOARDING_BACKFILL_RETENTION_HOURS=
ONBOARDING_BACKFILL_MAX_TERMINAL_JOBS=
ONBOARDING_BACKFILL_FAILURE_WINDOW_HOURS=
ONBOARDING_BACKFILL_STALLED_PENDING_MINUTES=

# -----------------------------------------------------------------------------
# Developer flags (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SHOW_ONBOARDING_DEV_TOOLS=

# -----------------------------------------------------------------------------
# Script-only helpers (optional)
# For Playwright tweet capture/challenge flows.
# -----------------------------------------------------------------------------
X_LOGIN_USERNAME=
X_LOGIN_PASSWORD=
X_LOGIN_EMAIL=
