X_API_BEARER_TOKEN=
ONBOARDING_MODE=auto
OPENAI_API_KEY=
# Optional: defaults to gpt-4.1-mini
# OPENAI_MODEL=gpt-4.1-mini
# Optional stage-specific routing:
# CHAT_PLANNER_PROVIDER=groq
# CHAT_WRITER_PROVIDER=openai
# CHAT_CRITIC_PROVIDER=groq
# OPENAI_PLANNER_MODEL=gpt-5-mini
# OPENAI_WRITER_MODEL=gpt-5-mini
# OPENAI_CRITIC_MODEL=gpt-5-mini
GROQ_API_KEY=
# Optional: defaults to llama-3.1-8b-instant
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_PLANNER_MODEL=llama-3.1-8b-instant
# GROQ_WRITER_MODEL=llama-3.3-70b-versatile
# GROQ_CRITIC_MODEL=llama-3.1-8b-instant
# Modes: auto | x_api | scrape | mock
#
# Optional overrides:
# ONBOARDING_STORE_PATH=/absolute/path/to/onboarding-runs.jsonl
# SCRAPE_STORE_PATH=/absolute/path/to/x-scrape-captures.jsonl
# NEXT_PUBLIC_SHOW_ONBOARDING_DEV_TOOLS=1
#
# Optional HTTP scrape vars (no browser/playwright):
# X_WEB_COOKIE=auth_token=...; ct0=...
# X_WEB_CSRF_TOKEN=<ct0>
# X_WEB_BEARER_TOKEN=<x-web-bearer-token>
# X_WEB_USER_TWEETS_QUERY_ID=<queryId>
# X_WEB_USER_ID=<rest_id>
# X_WEB_USER_AGENT=<user-agent>
# X_WEB_SESSION_FILE=/absolute/path/to/x-web-sessions.json
# Session pool JSON: [{"id":"worker_1","cookie":"auth_token=...; ct0=...","csrfToken":"..."}]
#
# Optional scrape scaling controls:
# X_WEB_SCRAPE_STATE_PATH=/absolute/path/to/x-http-scrape-state.json
# X_WEB_MAX_REQUESTS_PER_HOUR=45
# X_WEB_MIN_INTERVAL_MS=5000
# X_WEB_COOLDOWN_MS=1800000
